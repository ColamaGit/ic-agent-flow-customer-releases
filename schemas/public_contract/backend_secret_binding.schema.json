{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icaf.local/schemas/public_contract/backend_secret_binding.schema.json",
  "title": "Backend Secret Binding",
  "type": "object",
  "required": ["backend"],
  "properties": {
    "backend": {
      "type": "object",
      "required": ["provider", "secret_ref"],
      "properties": {
        "provider": { "type": "string" },
        "secret_ref": { "type": "object" },
        "required_env": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redact_on_export": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
